connector.name=hive
hive.metastore.uri=thrift://${GP2__HIVE_METASTORE__HOST_NAME}:${GP2__HIVE_METASTORE__PORT}
fs.native-s3.enabled=true
s3.endpoint=http://${GP2__MINIO__HOST_NAME}:${GP2__MINIO__API__PORT}
s3.region=us-east-1
s3.path-style-access=true
s3.aws-access-key=${GP2__MINIO__USER}
s3.aws-secret-key=${GP2__MINIO__PASSWORD}
hive.non-managed-table-writes-enabled=true
